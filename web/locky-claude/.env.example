# Kopiér til .env og udfyld værdierne

# PostgreSQL — bruges af både Flask (psycopg2/SQLAlchemy) og postgres-containeren
DATABASE_URL=postgresql://locky:hemmeligtkodeord@db:5432/lockydb
POSTGRES_DB=lockydb
POSTGRES_USER=locky
POSTGRES_PASSWORD=hemmeligtkodeord

# Flask session-kryptering — skift til noget tilfældigt og langt
FLASK_SECRET_KEY=skift-mig

# JWT-signering
JWT_SECRET_KEY=skift-mig-ogsaa

# AES-kryptering af JWT-tokens
SECRET_KEY=skift-mig-ligeledes

# MQTT — intern adresse inden i Docker-netværket
MQTT_HOST=mosquitto
MQTT_PORT=8883
MQTT_SERVER_USER=server
MQTT_SERVER_PASS=server123
MQTT_CONTROLLER_PASS=controller123
